# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Qwen (Alibaba Cloud DashScope, free tier) — optional, powers the
# knowledge-base auto-summary at incident close. Get a key at
# https://dashscope.console.aliyun.com/ — unset means KB entries still save,
# just with the technician's raw close note instead of an AI-cleaned version.
QWEN_API_KEY=sk-...
QWEN_MODEL=qwen-flash

# Telegram Bot — optional, powers incident/PM/SLA notifications
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij
TELEGRAM_WEBHOOK_SECRET=your_random_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Cron — required only if the SLA-escalation cron route is deployed
CRON_SECRET=your_random_secret

# Gudang One warehouse integration — optional
# Line ①: FAMMS pushes new parts requests to Gudang One
GUDANG_WEBHOOK_URL=https://<gudang-project>.supabase.co/functions/v1/famms-request
GUDANG_WEBHOOK_SECRET=same_secret_as_gudang_famms_request
# Line ③: Gudang One writes request status back to FAMMS
GUDANG_SYNC_SECRET=your_random_secret
# Warehouse for factories with no explicit mapping (e.g. LAB) — the request
# still goes through, tagged with the real factory in the note
GUDANG_DEFAULT_WAREHOUSE=DENIKIN
# Public — the Gudang One app URL, linked from the 叫料 form so a technician
# can jump over to check on their request. Safe to expose (just a URL).
NEXT_PUBLIC_GUDANG_APP_URL=https://gudang-one.denikin.co.id

# QC / FQMS integration — optional
# External read-only lookup of a machine's PM/health status
QC_API_SECRET=your_random_secret
